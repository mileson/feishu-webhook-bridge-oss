# 必填：飞书应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxx

# 启动时二选一：claude / codex
LOCAL_AI_PROVIDER=codex

# 如能自动探测则可不填；后台常驻时建议写绝对路径
# LOCAL_AI_COMMAND=/absolute/path/to/codex-or-claude

# 可选：通用运行配置
DEBUG=false
FEISHU_DISABLE_SYSTEM_PROXY=true
# LOCAL_AI_MODEL=
# LOCAL_AI_WORKING_DIR=/path/to/your/project
# LOCAL_AI_TIMEOUT=300

# 可选：Claude Code 自定义上游
# 当 LOCAL_AI_PROVIDER=claude 时可用。
# 这里需要一个兼容 Anthropic Messages API 的网关。
# 通过这种方式可以桥接 GLM、MiniMax、Kimi 等模型服务。
# CLAUDE_CODE_BASE_URL=https://your-compatible-gateway.example.com
# CLAUDE_CODE_AUTH_TOKEN=your-token
